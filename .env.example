# === Aktien-Dashboard Konfiguration ===

# Pflichtfeld: Passwort für den Dashboard-Zugang
DASHBOARD_PASSWORD=dein_sicheres_passwort

# LLM-Konfiguration (optional)
LLM_API_URL=https://api.ai.rh-koeln.de/v1/chat/completions
LLM_MODEL=mistral-large-3-675b-instruct-2512
LLM_API_KEY=dein_api_key_hier

# Session-Secret (wird automatisch generiert wenn nicht gesetzt)
# SESSION_SECRET=zufaelliger_string_hier

# Datenbank-Pfad (Standard: /app/data/watchlist.db)
# DB_PATH=/app/data/watchlist.db

# Cache-Dauer in Sekunden (Standard: 300 = 5 Minuten)
# CACHE_TTL=300
